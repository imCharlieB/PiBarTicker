{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run PiBarTicker Legacy",
			"type": "shell",
			"command": "C:/Users/jrwes/AppData/Local/Programs/Python/Python310/python.exe",
			"args": [
				"src/main.py"
			],
			"isBackground": false
		},
		{
			"label": "Run PiBarTicker Backend",
			"type": "shell",
			"command": "c:/Users/jrwes/source/Workspaces/PiBarTicker/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"uvicorn",
				"app.main:app",
				"--app-dir",
				"backend",
				"--reload"
			],
			"isBackground": true
		},
		{
			"label": "Build PiBarTicker Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": false
		},
		{
			"label": "Run PiBarTicker Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host=0.0.0.0"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true
		}
	]
}