[Unit]
Description=PiBarTicker FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/pibarticker
Environment=PYTHONUNBUFFERED=1
Environment=DISPLAY=:0
ExecStart=/opt/pibarticker/.venv/bin/python -m uvicorn app.main:app --app-dir backend --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
